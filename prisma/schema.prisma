generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  cashier
  barista
  admin
}

enum OrderStatus {
  pending
  preparing
  ready
  completed
  cancelled
}

enum PaymentMethod {
  cash
  promptpay
  card
  mockup
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum TableStatus {
  available
  occupied
  reserved
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Staff {
  id        String   @id @default(cuid())
  authId    String   @unique
  name      String
  role      Role     @default(cashier)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders   Order[]
  payments Payment[]

  @@map("staff")
  @@index([isActive])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menus Menu[]

  @@map("categories")
  @@index([isActive, sortOrder])
}

model Menu {
  id          String   @id @default(cuid())
  categoryId  String
  name        String   @unique
  description String?
  price       Decimal  @db.Decimal(10, 2)
  imageUrl    String?
  isAvailable Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // onDelete: Restrict — cannot delete a menu that appears in order history
  category   Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems OrderItem[]

  @@map("menus")
  @@index([categoryId, isAvailable, sortOrder])
}

model Table {
  id        String      @id @default(cuid())
  number    Int         @unique
  name      String
  capacity  Int         @default(4)
  status    TableStatus @default(available)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  orders Order[]

  @@map("tables")
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  tableId     String?
  staffId     String
  status      OrderStatus @default(pending)
  note        String?
  subtotal    Decimal     @db.Decimal(10, 2)
  discount    Decimal     @default(0) @db.Decimal(10, 2)
  total       Decimal     @db.Decimal(10, 2)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // onDelete: SetNull  — table can be reorganized without destroying order history
  // onDelete: Restrict — cannot delete staff who has orders (audit trail)
  table   Table?      @relation(fields: [tableId], references: [id], onDelete: SetNull)
  staff   Staff       @relation(fields: [staffId], references: [id], onDelete: Restrict)
  items   OrderItem[]
  payment Payment?
  receipt Receipt?

  @@map("orders")
  @@index([status, createdAt])
  @@index([staffId])
  @@index([tableId])
  @@index([createdAt])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  menuId    String
  menuName  String
  menuPrice Decimal  @db.Decimal(10, 2)
  quantity  Int
  note      String?
  lineTotal Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // onDelete: Cascade  — deleting an order removes all its items
  // onDelete: Restrict — cannot delete a menu that appears in order history
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menu  Menu  @relation(fields: [menuId], references: [id], onDelete: Restrict)

  @@map("order_items")
  @@index([orderId])
  @@index([menuId])
}

model Payment {
  id          String        @id @default(cuid())
  orderId     String        @unique
  staffId     String
  method      PaymentMethod
  status      PaymentStatus @default(pending)
  amount      Decimal       @db.Decimal(10, 2)
  gatewayRef  String?
  gatewayMeta Json?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // onDelete: Restrict — cannot delete an order that has a payment (audit trail)
  // onDelete: Restrict — cannot delete staff who processed a payment
  order   Order    @relation(fields: [orderId], references: [id], onDelete: Restrict)
  staff   Staff    @relation(fields: [staffId], references: [id], onDelete: Restrict)
  receipt Receipt?

  @@map("payments")
  @@index([status])
  @@index([staffId])
  @@index([method, paidAt])
}

model Receipt {
  id            String    @id @default(cuid())
  orderId       String    @unique
  paymentId     String    @unique
  receiptNumber String    @unique
  data          Json
  printedAt     DateTime?
  createdAt     DateTime  @default(now())

  // onDelete: Restrict — receipts are permanent audit records; protect against accidental deletion
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Restrict)
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  @@map("receipts")
  @@index([createdAt])
}
